{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "apps/api/bin/server.js",
    "apps/web/index.html",
    "apps/worker/src/worker.ts"
  ],
  "project": ["apps/**/package.json", "packages/**/package.json"],
  "ignore": [
    "apps/api/storage/**",
    "apps/api/.adonisjs/**",
    "apps/web/dist/**",
    "apps/web/node_modules/**",
    "apps/api/node_modules/**",
    "apps/worker/node_modules/**",
    "packages/**/node_modules/**",
    "packages/**/dist/**",
    "packages/**/build/**",
    "**/*.d.ts"
  ],
  "ignoreDependencies": [
    "@adonisjs/*",
    "@vinejs/vine",
    "luxon",
    "reflect-metadata",
    "pg",
    "@types/pg",
    "@types/luxon",
    "@types/node",
    "typescript",
    "vite",
    "vue",
    "vue-router",
    "pinia",
    "@tanstack/vue-query",
    "@vueuse/core",
    "reka-ui",
    "tailwindcss",
    "@nuxt/ui",
    "@vitejs/plugin-vue",
    "vitest",
    "vue-tsc",
    "eslint",
    "prettier",
    "@adonisjs/eslint-config",
    "@adonisjs/prettier-config",
    "@adonisjs/tsconfig",
    "@adonisjs/assembler",
    "@japa/*",
    "@poppinss/ts-exec",
    "pino-pretty",
    "youch",
    "hot-hook",
    "vue-eslint-parser",
    "typescript-eslint",
    "eslint-config-prettier",
    "eslint-plugin-vue",
    "lefthook",
    "lint-staged",
    "turbo",
    "knip",
    "dependency-cruiser",
    "eslint-plugin-unicorn",
    "@commitlint/cli",
    "@commitlint/config-conventional"
  ]
}
