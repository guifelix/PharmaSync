{
  "forbidden": [
    {
      "name": "no-circular",
      "comment": "No circular dependencies",
      "severity": "error",
      "from": { "path": "^apps" },
      "to": { "path": "^apps" }
    },
    {
      "name": "no-circular-packages",
      "comment": "No circular dependencies in packages",
      "severity": "error",
      "from": { "path": "^packages" },
      "to": { "path": "^packages" }
    },
    {
      "name": "apps-only-import-packages",
      "comment": "Apps can only import from packages",
      "severity": "error",
      "from": { "path": "^apps" },
      "to": { "pathNot": ["^packages", "^node_modules"] }
    },
    {
      "name": "packages-only-import-packages",
      "comment": "Packages can only import from packages",
      "severity": "error",
      "from": { "path": "^packages" },
      "to": { "pathNot": ["^packages", "^node_modules"] }
    },
    {
      "name": "no-cross-package-imports",
      "comment": "Packages should not import from other packages' src",
      "severity": "error",
      "from": { "path": "^packages/[^/]+/src" },
      "to": { "path": "^packages/[^/]+/src", "pathNot": "^packages/[^/]+/src" }
    }
  ],
  "options": {
    "prefix": "^(apps|packages)/",
    "tsConfig": {
      "fileName": "tsconfig.base.json"
    },
    "exclude": [
      "node_modules",
      "dist",
      "build",
      "\\.adonisjs",
      "storage",
      "\\.d\\.ts$"
    ],
    "doNotFollow": {
      "path": "node_modules"
    },
    "progress": {
      "type": "cli-feedback"
    }
  }
}
