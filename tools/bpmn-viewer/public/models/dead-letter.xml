    <bpmn:sequenceFlow id="Flow_jQpcw53y" sourceRef="dead-letter-received" targetRef="store-dead-letter"/>
    <bpmn:sequenceFlow id="Flow_QXo1coMy" sourceRef="store-dead-letter" targetRef="alert-operations"/>
    <bpmn:sequenceFlow id="Flow_FbxGHKWU" sourceRef="alert-operations" targetRef="log-audit"/>
    <bpmn:sequenceFlow id="Flow_NL01vPpn" sourceRef="log-audit" targetRef="dead-letter-handled"/>
