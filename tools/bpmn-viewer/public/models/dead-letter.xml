        <zeebe:taskDefinition type="dead-letter-store" retries="3"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_jQpcw53y</bpmn:incoming>
      <bpmn:outgoing>Flow_QXo1coMy</bpmn:outgoing>
