<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="@bpmnkit/core" exporterVersion="0.0.23" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="partner-certification" name="Partner Certification" isExecutable="true">
    <bpmn:startEvent id="certification-started" name="Certification Started">
      <bpmn:outgoing>Flow_HMgWOI1J</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="assign-reviewer" name="Assign Certification Reviewer">
      <bpmn:extensionElements>
        <zeebe:userTask/>
        <zeebe:formDefinition formId="certification-reviewer-form"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_HMgWOI1J</bpmn:incoming>
      <bpmn:outgoing>Flow_fZqTFys4</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="evaluate-documentation" name="Evaluate Partner Documentation">
      <bpmn:extensionElements>
        <zeebe:userTask/>
        <zeebe:formDefinition formId="documentation-evaluation-form"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_fZqTFys4</bpmn:incoming>
      <bpmn:outgoing>Flow_v4HRn6QO</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="certification-decision" name="Certify or Request Improvements?">
      <bpmn:incoming>Flow_v4HRn6QO</bpmn:incoming>
      <bpmn:outgoing>Flow_cvs6Wag0</bpmn:outgoing>
      <bpmn:outgoing>Flow_Rn9GwmVa</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="issue-certificate" name="Issue Certificate">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="certificate-issuer" retries="3"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_cvs6Wag0</bpmn:incoming>
      <bpmn:outgoing>Flow_SoYBHVuA</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="certified" name="Partner Certified">
      <bpmn:incoming>Flow_SoYBHVuA</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="request-improvements" name="Request Improvements">
      <bpmn:extensionElements>
        <zeebe:userTask/>
        <zeebe:formDefinition formId="improvement-request-form"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Rn9GwmVa</bpmn:incoming>
      <bpmn:outgoing>Flow_cnaQyYXL</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="improvements-needed" name="Improvements Needed">
      <bpmn:incoming>Flow_cnaQyYXL</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_HMgWOI1J" sourceRef="certification-started" targetRef="assign-reviewer"/>
    <bpmn:sequenceFlow id="Flow_fZqTFys4" sourceRef="assign-reviewer" targetRef="evaluate-documentation"/>
    <bpmn:sequenceFlow id="Flow_v4HRn6QO" sourceRef="evaluate-documentation" targetRef="certification-decision"/>
    <bpmn:sequenceFlow id="Flow_cvs6Wag0" sourceRef="certification-decision" targetRef="issue-certificate" name="certify">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= certify</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_SoYBHVuA" sourceRef="issue-certificate" targetRef="certified"/>
    <bpmn:sequenceFlow id="Flow_Rn9GwmVa" sourceRef="certification-decision" targetRef="request-improvements" name="improvements">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= improvements</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_cnaQyYXL" sourceRef="request-improvements" targetRef="improvements-needed"/>
  </bpmn:process>
</bpmn:definitions>

