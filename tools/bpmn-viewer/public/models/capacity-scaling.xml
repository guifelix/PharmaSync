      <bpmn:incoming>Flow_86WJLv5C</bpmn:incoming>
      <bpmn:outgoing>Flow_4oG5wZyE</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="scale-up" name="Scale Up Resources">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="resource-scaler" retries="3"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_4oG5wZyE</bpmn:incoming>
      <bpmn:outgoing>Flow_jPVQsdGs</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="scaled-up" name="Scaled Up">
      <bpmn:incoming>Flow_jPVQsdGs</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="assess-scale-down" name="Assess Scale-Down">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="scale-down-assessor" retries="3"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_z7zbLGqB</bpmn:incoming>
      <bpmn:outgoing>Flow_kOOaBeNM</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="scale-down" name="Scale Down Resources">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="resource-scaler" retries="3"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_kOOaBeNM</bpmn:incoming>
      <bpmn:outgoing>Flow_2Kddp74x</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="scaled-down" name="Scaled Down">
      <bpmn:incoming>Flow_2Kddp74x</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="log-normal" name="Log Normal State">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="normal-logger" retries="3"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0neE59dj</bpmn:incoming>
      <bpmn:outgoing>Flow_V4vegYIJ</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="normal" name="Within Threshold">
      <bpmn:incoming>Flow_V4vegYIJ</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_la11lP0q" sourceRef="scaling-check" targetRef="monitor-metrics"/>
    <bpmn:sequenceFlow id="Flow_sDjhZEa7" sourceRef="monitor-metrics" targetRef="threshold"/>
    <bpmn:sequenceFlow id="Flow_86WJLv5C" sourceRef="threshold" targetRef="assess-scale-up" name="over">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= overThreshold</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_4oG5wZyE" sourceRef="assess-scale-up" targetRef="scale-up"/>
    <bpmn:sequenceFlow id="Flow_jPVQsdGs" sourceRef="scale-up" targetRef="scaled-up"/>
