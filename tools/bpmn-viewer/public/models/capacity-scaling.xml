      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= underThreshold</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_kOOaBeNM" sourceRef="assess-scale-down" targetRef="scale-down"/>
    <bpmn:sequenceFlow id="Flow_2Kddp74x" sourceRef="scale-down" targetRef="scaled-down"/>
    <bpmn:sequenceFlow id="Flow_0neE59dj" sourceRef="threshold" targetRef="log-normal" name="normal">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= withinThreshold</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_V4vegYIJ" sourceRef="log-normal" targetRef="normal"/>
  </bpmn:process>
